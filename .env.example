QUART_SECRET_KEY=a-very-secret-key

# enter your MAM ID from https://www.myanonamouse.net/preferences/index.php?view=security
MAM_ID=mam_id_here-generated_from_myanonamouse_website

# QBittorrent Settings & Credentials
QB_URL=http://qbittorrent:6767
QB_USERNAME=your_qbittorrent_username
QB_PASSWORD=your_qbittorrent_password
QB_CATEGORY=audiobooks # default qBittorrent category to select for downloads


# Enable this to have MouseSearch automatically hard link files when torrents are added
# from the "organize-these" folder to the "organized" folder in Author/Title format.
AUTO_ORGANIZE_ON_ADD=true

# Enable this to have MouseSearch check for unorganized files on a schedule (every hour)
AUTO_ORGANIZE_ON_SCHEDULE=true

# Download Storage Paths (if using auto-organization)
# - must ensure these paths are on the same device and Docker volume, if running in Docker) 
#   to ensure hard links can be created

QB_PATH=/downloads/torrents/audiobooks
ORGANIZED_PATH=/downloads/organized/audiobooks

# Recommended File Structure 

# downloads
# ├── organized
# │   ├── audiobooks
# │   └── ebooks
# └── torrents
#     ├── audiobooks
#     └── ebooks
